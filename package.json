{
  "name": "mcp-multitool",
  "version": "0.1.7",
  "description": "MCP server with file operations (delete, move) and timing utilities.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
